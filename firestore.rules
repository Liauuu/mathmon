rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // users/{userId}/vaults — 문제 저장소
    match /users/{userId}/vaults/{vaultId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['name', 'problemIds', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.problemIds is list
        && request.resource.data.problemIds.size() == 0
        && request.resource.data.createdAt is number;

      allow update: if isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.problemIds is list
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isOwner(userId);

      // users/{userId}/vaults/{vaultId}/problems — 저장된 연습문제
      match /problems/{problemId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['problem', 'answer', 'index', 'savedAt'])
          && request.resource.data.problem is string
          && request.resource.data.answer is string
          && request.resource.data.index is int
          && request.resource.data.index >= 0
          && request.resource.data.index <= 2;

        allow update, delete: if isOwner(userId);
      }
    }

    // AI 훈련용 데이터셋 (본인만 생성·조회)
    match /ai_training_data/{docId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'original_extracted_text',
          'generated_twin_problems',
          'saved_at',
          'userId',
          'vaultId',
        ])
        && request.resource.data.original_extracted_text is string
        && request.resource.data.generated_twin_problems is map
        && request.resource.data.vaultId is string;

      allow update, delete: if false;
    }
  }
}
